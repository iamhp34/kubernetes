#!/bin/bash
set -euo pipefail

ROLE="${1:-}"
MASTER_IP="${2:-}"
POD_CIDR="${3:-192.168.0.0/16}"
K8S_VERSION="${4:-v1.35}"

usage() {
  echo "Usage:"
  echo "  sudo bash k8s-amazonlinux.sh master <MASTER_PRIVATE_IP> [POD_CIDR] [K8S_VERSION]"
  echo "  sudo bash k8s-amazonlinux.sh worker"
  echo
  echo "Examples:"
  echo "  sudo bash k8s-amazonlinux.sh master 10.0.1.10"
  echo "  sudo bash k8s-amazonlinux.sh worker"
  exit 1
}

if [[ $EUID -ne 0 ]]; then
  echo "Run this script as root: sudo bash $0 ..."
  exit 1
fi

if [[ "$ROLE" != "master" && "$ROLE" != "worker" ]]; then
  usage
fi

if [[ "$ROLE" == "master" && -z "$MASTER_IP" ]]; then
  usage
fi

USER_NAME="$(logname 2>/dev/null || echo ec2-user)"
USER_HOME="/home/${USER_NAME}"

echo "===== Kubernetes node setup started for role: $ROLE ====="
echo "Node hostname: $(hostname)"
echo "Node IP: $(hostname -I | awk '{print $1}')"

echo "===== Disable swap ====="
swapoff -a || true
sed -i.bak '/[[:space:]]swap[[:space:]]/ s/^/#/' /etc/fstab || true

echo "===== Disable SELinux ====="
setenforce 0 || true
if [[ -f /etc/selinux/config ]]; then
  sed -i 's/^SELINUX=.*/SELINUX=disabled/' /etc/selinux/config || true
fi

echo "===== Handle firewall if firewalld exists ====="
if systemctl list-unit-files | grep -q '^firewalld.service'; then
  echo "WARNING: firewalld is being disabled (not recommended for production)"
  systemctl stop firewalld || true
  systemctl disable firewalld || true
fi

echo "===== Load kernel modules ====="
cat >/etc/modules-load.d/k8s.conf <<EOF
overlay
br_netfilter
EOF

modprobe overlay
modprobe br_netfilter

echo "===== Configure sysctl ====="
cat >/etc/sysctl.d/k8s.conf <<EOF
net.bridge.bridge-nf-call-iptables = 1
net.bridge.bridge-nf-call-ip6tables = 1
net.ipv4.ip_forward = 1
EOF

sysctl --system

echo "===== Update packages ====="
dnf update -y

echo "===== Install containerd ====="
dnf install -y containerd

mkdir -p /etc/containerd
containerd config default >/etc/containerd/config.toml

sed -i 's/SystemdCgroup = false/SystemdCgroup = true/' /etc/containerd/config.toml

systemctl daemon-reload
systemctl enable --now containerd
systemctl restart containerd

echo "===== Checking container runtime ====="
systemctl status containerd --no-pager || true

echo "===== Add Kubernetes repo ====="
cat >/etc/yum.repos.d/kubernetes.repo <<EOF
[kubernetes]
name=Kubernetes
baseurl=https://pkgs.k8s.io/core:/stable:/${K8S_VERSION}/rpm/
enabled=1
gpgcheck=1
gpgkey=https://pkgs.k8s.io/core:/stable:/${K8S_VERSION}/rpm/repodata/repomd.xml.key
exclude=kubelet kubeadm kubectl cri-tools kubernetes-cni
EOF

echo "===== Install kubelet kubeadm kubectl ====="
dnf install -y kubelet kubeadm kubectl --disableexcludes=kubernetes

systemctl enable --now kubelet

if [[ "$ROLE" == "master" ]]; then
  echo "===== Initialize control plane ====="
  kubeadm init \
    --apiserver-advertise-address="${MASTER_IP}" \
    --pod-network-cidr="${POD_CIDR}" \
    --ignore-preflight-errors=NumCPU

  echo "===== Configure kubectl for ${USER_NAME} ====="
  mkdir -p "${USER_HOME}/.kube"
  cp -i /etc/kubernetes/admin.conf "${USER_HOME}/.kube/config"
  chown -R "${USER_NAME}:${USER_NAME}" "${USER_HOME}/.kube"

  export KUBECONFIG=/etc/kubernetes/admin.conf

  echo "===== Install Calico CNI ====="
  kubectl apply -f https://raw.githubusercontent.com/projectcalico/calico/v3.31.4/manifests/calico.yaml

  echo "===== Wait a few seconds and show nodes ====="
  sleep 10
  kubectl get nodes -o wide
  kubectl get pods -A

  echo "===== Worker join command ====="
  kubeadm token create --print-join-command

  echo "===== IMPORTANT ====="
  echo "Copy the join command above and run it on worker nodes"

else
  echo "===== Worker setup completed ====="
  echo "Run the join command from the master node, for example:"
  echo "kubeadm join <MASTER_IP>:6443 --token <TOKEN> --discovery-token-ca-cert-hash sha256:<HASH>"
fi

echo "===== Done ====="

: <<'COMMENT'
# On master node
curl -O https://raw.githubusercontent.com/iamhp34/kubernetes/main/amazonlinux/k8s-amazonlinux.sh
chmod +x k8s-amazonlinux.sh
sudo ./k8s-amazonlinux.sh master 10.0.1.10
COMMENT

: <<'COMMENT'
# On worker node
curl -O https://raw.githubusercontent.com/iamhp34/kubernetes/main/amazonlinux/k8s-amazonlinux.sh
chmod +x k8s-amazonlinux.sh
sudo ./k8s-amazonlinux.sh worker
COMMENT
