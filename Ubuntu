#!/bin/bash
set -euo pipefail

ROLE="${1:-}"
K8S_VERSION="${2:-v1.35}"

usage() {
  echo "Usage:"
  echo "  sudo bash k8s-ubuntu.sh master [K8S_VERSION]"
  echo "  sudo bash k8s-ubuntu.sh worker [K8S_VERSION]"
  echo
  echo "Examples:"
  echo "  sudo bash k8s-ubuntu.sh master"
  echo "  sudo bash k8s-ubuntu.sh worker"
  echo "  sudo bash k8s-ubuntu.sh master v1.35"
  exit 1
}

if [[ $EUID -ne 0 ]]; then
  echo "Run this script as root: sudo bash $0 ..."
  exit 1
fi

if [[ "$ROLE" != "master" && "$ROLE" != "worker" ]]; then
  usage
fi

USER_NAME="$(logname 2>/dev/null || echo ubuntu)"
USER_HOME="$(eval echo "~${USER_NAME}")"

echo "===== Kubernetes node setup started for role: $ROLE ====="
echo "Node hostname: $(hostname)"
echo "Node IP: $(hostname -I | awk '{print $1}')"

echo "===== Disable swap ====="
swapoff -a || true
sed -i.bak '/[[:space:]]swap[[:space:]]/ s/^/#/' /etc/fstab || true

echo "===== Handle firewall if UFW exists ====="
if command -v ufw >/dev/null 2>&1; then
  echo "WARNING: UFW is being disabled (not recommended for production)"
  ufw disable || true
fi

echo "===== Load kernel modules ====="
cat >/etc/modules-load.d/k8s.conf <<EOF
overlay
br_netfilter
EOF

modprobe overlay
modprobe br_netfilter

echo "===== Configure sysctl ====="
cat >/etc/sysctl.d/k8s.conf <<EOF
net.bridge.bridge-nf-call-iptables = 1
net.bridge.bridge-nf-call-ip6tables = 1
net.ipv4.ip_forward = 1
EOF

sysctl --system

echo "===== Update packages ====="
apt-get update
apt-get install -y apt-transport-https ca-certificates curl gpg

echo "===== Install containerd ====="
apt-get install -y containerd

mkdir -p /etc/containerd
containerd config default >/etc/containerd/config.toml

sed -i 's/SystemdCgroup = false/SystemdCgroup = true/' /etc/containerd/config.toml

systemctl daemon-reload
systemctl enable --now containerd
systemctl restart containerd

echo "===== Checking container runtime ====="
systemctl status containerd --no-pager || true

echo "===== Add Kubernetes repo ====="
mkdir -p -m 755 /etc/apt/keyrings
curl -fsSL "https://pkgs.k8s.io/core:/stable:/${K8S_VERSION}/deb/Release.key" \
  | gpg --dearmor --batch --yes -o /etc/apt/keyrings/kubernetes-apt-keyring.gpg

cat >/etc/apt/sources.list.d/kubernetes.list <<EOF
deb [signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] https://pkgs.k8s.io/core:/stable:/${K8S_VERSION}/deb/ /
EOF

apt-get update

echo "===== Install kubelet kubeadm kubectl ====="
apt-get install -y kubelet kubeadm kubectl
apt-mark hold kubelet kubeadm kubectl

systemctl enable --now kubelet

if [[ "$ROLE" == "master" ]]; then
  echo "===== Master node prerequisites completed ====="
  echo "Run kubeadm init manually, for example:"
  echo "sudo kubeadm init --apiserver-advertise-address=<MASTER_PRIVATE_IP> --pod-network-cidr=192.168.0.0/16"
  echo
  echo "After kubeadm init succeeds, re-run this script once to place kubeconfig automatically if /etc/kubernetes/admin.conf exists."
fi

if [[ "$ROLE" == "worker" ]]; then
  echo "===== Worker node prerequisites completed ====="
  echo "After master is initialized, run the join command on this worker."
fi

if [[ "$ROLE" == "master" && -f /etc/kubernetes/admin.conf ]]; then
  echo "===== Configure kubectl for ${USER_NAME} ====="
  if [[ ! -f "${USER_HOME}/.kube/config" ]]; then
    mkdir -p "${USER_HOME}/.kube"
    cp /etc/kubernetes/admin.conf "${USER_HOME}/.kube/config"
    chown -R "${USER_NAME}:${USER_NAME}" "${USER_HOME}/.kube"
  fi
fi

echo "===== Done ====="

: <<'COMMENT'
# On master node
curl -L -o k8s-ubuntu.sh https://raw.githubusercontent.com/iamhp34/kubernetes/main/Ubuntu
chmod +x k8s-ubuntu.sh
sudo ./k8s-ubuntu.sh master

# Then run manually on master
sudo kubeadm init --apiserver-advertise-address=<MASTER_PRIVATE_IP> --pod-network-cidr=192.168.0.0/16

# Re-run script once to place kubeconfig automatically
sudo ./k8s-ubuntu.sh master

# Install Calico CNI manually on master
kubectl apply -f https://raw.githubusercontent.com/projectcalico/calico/v3.31.4/manifests/calico.yaml

# Verify Calico
kubectl get pods -n kube-system | grep calico
COMMENT

: <<'COMMENT'
# On worker node
curl -L -o k8s-ubuntu.sh https://raw.githubusercontent.com/iamhp34/kubernetes/main/Ubuntu
chmod +x k8s-ubuntu.sh
sudo ./k8s-ubuntu.sh worker

# Then run the join command manually on worker
sudo kubeadm join <MASTER_IP>:6443 --token <TOKEN> --discovery-token-ca-cert-hash sha256:<HASH>
COMMENT
